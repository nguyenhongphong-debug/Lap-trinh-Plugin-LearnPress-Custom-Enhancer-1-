import React from 'react';
import { NotificationBar } from './components/NotificationBar';
import { CourseInfo } from './components/CourseInfo';
import { MOCK_COURSES } from './data/courses';
import { GraduationCap, ArrowRight } from 'lucide-react';
import { motion } from 'motion/react';

export default function App() {
  // Simulating a logged-in user
  const [user, setUser] = React.useState<{ name: string } | null>({ name: "Nguyễn Hồng Phong" });

  const toggleAuth = () => {
    setUser(user ? null : { name: "Nguyễn Hồng Phong" });
  };

  return (
    <div className="min-h-screen bg-gray-50 font-sans">
      {/* Yêu cầu 1: Notification Bar */}
      <NotificationBar user={user} />

      <main className="max-w-7xl mx-auto px-4 py-12">
        <header className="mb-12 flex flex-col md:flex-row md:items-end justify-between gap-6">
          <div>
            <div className="flex items-center gap-2 text-indigo-600 font-bold mb-2">
              <GraduationCap className="w-8 h-8" />
              <span className="text-xl tracking-tight">LearnFlow LMS</span>
            </div>
            <h1 className="text-4xl font-extrabold text-gray-900 tracking-tight">
              Khám phá các khóa học mới nhất
            </h1>
            <p className="text-gray-500 mt-2 text-lg">
              Nâng cao kỹ năng của bạn với lộ trình học tập chuyên nghiệp.
            </p>
          </div>
          
          <button 
            onClick={toggleAuth}
            className="px-6 py-2 bg-white border border-gray-200 rounded-full text-sm font-medium hover:bg-gray-50 transition-all shadow-sm"
          >
            {user ? "Đăng xuất (Demo)" : "Đăng nhập (Demo)"}
          </button>
        </header>

        <div className="space-y-16">
          {MOCK_COURSES.map((course, index) => (
            <motion.section 
              key={course.id}
              initial={{ opacity: 0, y: 20 }}
              whileInView={{ opacity: 1, y: 0 }}
              viewport={{ once: true }}
              transition={{ delay: index * 0.1 }}
              className="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start"
            >
              <div className="lg:col-span-5">
                <div className="relative group overflow-hidden rounded-3xl shadow-xl">
                  <img 
                    src={course.thumbnail} 
                    alt={course.title}
                    className="w-full aspect-video object-cover group-hover:scale-105 transition-transform duration-500"
                    referrerPolicy="no-referrer"
                  />
                  <div className="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity flex items-end p-6">
                    <span className="text-white font-bold flex items-center gap-2">
                      Xem chi tiết <ArrowRight className="w-4 h-4" />
                    </span>
                  </div>
                </div>
              </div>

              <div className="lg:col-span-7 space-y-6">
                <div>
                  <h2 className="text-3xl font-bold text-gray-900 mb-4">{course.title}</h2>
                  
                  {/* Yêu cầu 2: Shortcode [lp_course_info id="xxx"] */}
                  <CourseInfo id={course.id} />
                </div>

                <div className="flex flex-wrap gap-4 pt-4">
                  {/* Yêu cầu 3: Custom CSS (Implemented via Tailwind classes representing brand colors) */}
                  {!course.enrolled ? (
                    <button className="btn-enroll">
                      Ghi danh ngay
                    </button>
                  ) : course.completed ? (
                    <button className="btn-finish opacity-50 cursor-not-allowed">
                      Đã hoàn thành
                    </button>
                  ) : (
                    <button className="btn-finish">
                      Hoàn thành khóa học
                    </button>
                  )}
                  
                  <button className="px-8 py-4 rounded-2xl font-bold text-gray-600 hover:bg-gray-100 transition-all">
                    Xem đề cương
                  </button>
                </div>
              </div>
            </motion.section>
          ))}
        </div>
      </main>

      <footer className="bg-white border-t border-gray-200 py-12 mt-24">
        <div className="max-w-7xl mx-auto px-4 text-center">
          <p className="text-gray-400 text-sm">
            © 2026 LearnFlow LMS. Plugin Demo for Course Management.
          </p>
        </div>
      </footer>
    </div>
  );
}
